# =============================================================================
# AutoML-Agent Environment Configuration
# Copy this file to .env and fill in your keys.
# =============================================================================

# --- LLM Provider Keys ---
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- External Service Keys ---
# HuggingFace (Read token): https://huggingface.co/settings/tokens
# Only needs READ access (list datasets, list models, download)
HF_API_KEY=
# PapersWithCode: NOT USED — data is loaded from local JSON files.
# PWC was acquired by HuggingFace; no separate API key needed.
PWC_API_KEY=
# Kaggle API Token (KGAT_xxx): https://www.kaggle.com/settings/account → "Create New Token"
# The KGAT_ prefix is Kaggle's OAuth access token (kaggle >= 1.6).
# Alternative: create ~/.kaggle/kaggle.json with {"username":"...","key":"..."}
KAGGLE_API_TOKEN=
# SerpAPI (Google Search): https://serpapi.com/manage-api-key
SEARCHAPI_API_KEY=
# Tavily (web search): https://tavily.com/ → Dashboard → API Key
TAVILY_API_KEY=

# --- LLM Selection ---
# Main backbone LLM for all agents (plan generation, code gen, etc.).
#
# Accepts EITHER:
#   • A registered alias  → or-glm-5, or-claude-sonnet, or-gpt-5-mini, or-deepseek-r1 …
#   • Any OpenRouter slug → z-ai/glm-5, anthropic/claude-opus-4.6, qwen/qwen3.5-flash-02-23 …
#
# Browse slugs at: https://openrouter.ai/models
# Full alias list:  python -m cli list-models
LLM_BACKBONE=or-glm-5

# LLM for PromptAgent (JSON parsing / prompt decomposition). Use a fast/cheap model.
# Accepts the same alias-or-slug format as LLM_BACKBONE.
# Set to "prompt-llm" to use the local vLLM fine-tuned adapter instead.
LLM_PROMPT_AGENT=or-gpt-5-nano

# --- LangSmith Observability (optional) ---
# Sign up free at https://smith.langchain.com/ → Settings → API Keys
# When LANGCHAIN_TRACING_V2=true every LLM call is traced automatically.
# pip install langsmith  (already in requirements.txt)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=automl-agent

# --- OpenRouter Workflow Override (optional) ---
# If set, overrides LLM_BACKBONE for the ENTIRE workflow (all agents use this model).
# Useful for quick one-off experiments without changing LLM_BACKBONE.
# Accepts any raw OpenRouter slug (e.g. "anthropic/claude-opus-4.6").
# Leave blank to use the value from LLM_BACKBONE.
OPENROUTER_MODEL=

# --- Local vLLM (optional, for PromptAgent fine-tuned adapter) ---
VLLM_BASE_URL=http://localhost:8000/v1
